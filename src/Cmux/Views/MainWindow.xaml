<Window x:Class="Cmux.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Cmux.ViewModels"
        xmlns:views="clr-namespace:Cmux.Views"
        xmlns:controls="clr-namespace:Cmux.Controls"
        Title="cmux windows" Height="800" Width="1200"
        MinHeight="400" MinWidth="600"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        Loaded="OnLoaded" Closing="OnClosing"
        KeyDown="OnKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                      ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF141420" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFE2E2E9" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF252547" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFE2E2E9" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF141420" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF141420" />

        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF141420" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#FF252547" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF2A2A3C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FF2A2A3C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FF2A2A3C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#FF2A2A3C" />

        <Style x:Key="AppMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource SidebarBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Padding" Value="4,2" />
        </Style>

        <Style x:Key="AppMenuTopItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="TopItemBg" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}">
                                <Border Background="#FF141420" BorderBrush="#FF2A2A3C" BorderThickness="1" Padding="4" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopItemBg" Property="Background" Value="#FF1A1A2E" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="TopItemBg" Property="Background" Value="#FF1A1A2E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppMenuSubItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="SubItemBg" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" ContentSource="Header" RecognizesAccessKey="True" />
                                <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}" Margin="14,0,0,0"
                                           Foreground="{StaticResource ForegroundDimBrush}" FontSize="11" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="SubItemBg" Property="Background" Value="#FF252547" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource ForegroundDimBrush}" />
                                <Setter TargetName="SubItemBg" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Margin="6,4" Background="#FF2A2A3C" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border x:Name="WindowBorder" Background="{StaticResource BackgroundBrush}"
            CornerRadius="{StaticResource WindowCornerRadius}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Clip>
            <RectangleGeometry x:Name="WindowClipGeometry" RadiusX="10" RadiusY="10" />
        </Border.Clip>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Height="38">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Menu items -->
                        <ColumnDefinition Width="*" />    <!-- Drag area -->
                        <ColumnDefinition Width="Auto" /> <!-- Window buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- Menu items (left side) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="cmuxw" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="14,0,12,0" />
                        <Menu Style="{StaticResource AppMenuStyle}" VerticalAlignment="Center">
                            <Menu.Resources>
                                <Style TargetType="Separator" BasedOn="{StaticResource AppMenuSeparatorStyle}" />
                            </Menu.Resources>
                            <MenuItem Header="_File" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="_New Workspace" Command="{Binding CreateNewWorkspaceCommand}" InputGestureText="Ctrl+N" />
                                <MenuItem Header="New _Surface" Command="{Binding SelectedWorkspace.CreateNewSurfaceCommand}" InputGestureText="Ctrl+T" />
                                <Separator />
                                <MenuItem Header="Open Command _Logs" Click="MenuOpenLogs_Click" InputGestureText="Ctrl+Shift+L" />
                                <MenuItem Header="Open Session _Vault" Click="MenuOpenSessionVault_Click" InputGestureText="Ctrl+Shift+V" />
                                <Separator />
                                <MenuItem Header="_Settings" Click="MenuOpenSettings_Click" InputGestureText="Ctrl+," />
                                <Separator />
                                <MenuItem Header="E_xit" Click="CloseButton_Click" />
                            </MenuItem>
                            <MenuItem Header="_Window" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="Split _Right" Click="ToolbarSplitRight_Click" InputGestureText="Ctrl+D" />
                                <MenuItem Header="Split _Down" Click="ToolbarSplitDown_Click" InputGestureText="Ctrl+Shift+D" />
                                <MenuItem Header="_Zoom Pane" Click="ToolbarZoom_Click" InputGestureText="Ctrl+Shift+Z" />
                                <MenuItem Header="_Equalize Panes" Click="ToolbarEqualize_Click" />
                                <Separator />
                                <MenuItem Header="_Search" Click="Search_Click" InputGestureText="Ctrl+Shift+F" />
                                <MenuItem Header="Command _Palette" Click="CommandPalette_Click" InputGestureText="Ctrl+Shift+P" />
                                <MenuItem Header="_Snippets" Click="Snippets_Click" />
                                <Separator />
                                <MenuItem Header="Toggle _Sidebar" Command="{Binding ToggleSidebarCommand}" InputGestureText="Ctrl+B" />
                            </MenuItem>
                            <MenuItem Header="_Help" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="Keyboard Shortcuts" Click="MenuOpenKeyboardShortcuts_Click" />
                                <MenuItem Header="About" Click="MenuAbout_Click" />
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <!-- Drag area (center) -->
                    <Border Grid.Column="1" Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />

                    <!-- Window control buttons (right side) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowChromeButton}" Click="MinimizeButton_Click"
                                ToolTip="Minimize">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button x:Name="MaxRestoreButton" Style="{StaticResource WindowChromeButton}"
                                Click="MaximizeButton_Click" ToolTip="Maximize">
                            <TextBlock x:Name="MaxRestoreIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_Click"
                                ToolTip="Close">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="280" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border x:Name="SidebarBorder" Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Sidebar top actions -->
                        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="8,8,8,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                                    <TextBlock Text="Workspaces" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="Manage sessions and environments" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}" ToolTip="New Workspace (Ctrl+N)"
                                            Width="24" Height="24" Command="{Binding CreateNewWorkspaceCommand}">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" ToolTip="Session Vault (Ctrl+Shift+V)"
                                            Width="24" Height="24" Click="MenuOpenSessionVault_Click">
                                        <TextBlock Text="&#xE8D1;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" ToolTip="Command Logs (Ctrl+Shift+L)"
                                            Width="24" Height="24" Click="MenuOpenLogs_Click">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                </StackPanel>

                                <TextBox x:Name="WorkspaceFilterBox"
                                         Grid.Row="1" Grid.ColumnSpan="2"
                                         Margin="0,8,0,0" Padding="8,5"
                                         Background="#FF141420" Foreground="{StaticResource ForegroundBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         CaretBrush="{StaticResource ForegroundBrush}" SelectionBrush="{StaticResource AccentBrush}"
                                         ToolTip="Filter workspaces by name, branch, or directory"
                                         TextChanged="WorkspaceFilterBox_TextChanged" />
                            </Grid>
                        </Border>

                        <!-- Workspace list -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding Workspaces}"
                                 SelectedItem="{Binding SelectedWorkspace}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 AllowDrop="True" Padding="4,4,4,0"
                                 x:Name="WorkspaceList">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
                                    <controls:WorkspaceSidebarItem />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,1" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <!-- Active indicator bar (left edge) -->
                                                    <Rectangle x:Name="activeBar" Width="3" HorizontalAlignment="Left"
                                                               RadiusX="1.5" RadiusY="1.5" Opacity="0"
                                                               Margin="0,4">
                                                        <Rectangle.Fill>
                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                <GradientStop Color="#FF6366F1" Offset="0" />
                                                                <GradientStop Color="#FFA78BFA" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Rectangle.Fill>
                                                    </Rectangle>
                                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                                            CornerRadius="8" Padding="10,8" Margin="6,0,2,0">
                                                        <ContentPresenter />
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background"
                                                                Value="{StaticResource SidebarItemHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background"
                                                                Value="{StaticResource SidebarItemSelectedBrush}" />
                                                        <Setter TargetName="activeBar" Property="Opacity" Value="1" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="WorkspaceItem_PreviewMouseDown" />
                                    <EventSetter Event="PreviewMouseMove" Handler="WorkspaceItem_PreviewMouseMove" />
                                    <EventSetter Event="Drop" Handler="WorkspaceItem_Drop" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Sidebar footer -->
                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0" Padding="6,6">
                            <StackPanel>
                                <Button Command="{Binding CreateNewWorkspaceCommand}"
                                        Style="{StaticResource CmuxButton}"
                                        HorizontalAlignment="Stretch" Margin="0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Margin="0,0,8,0" Opacity="0.6" />
                                        <TextBlock Text="New Workspace" FontSize="12" />
                                    </StackPanel>
                                </Button>

                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="TemplateButton" Grid.Column="0"
                                            Style="{StaticResource CmuxButton}"
                                            HorizontalAlignment="Stretch" Margin="0,0,2,0"
                                            ToolTip="New from Template"
                                            Click="TemplateButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       Margin="0,0,6,0" Opacity="0.6" />
                                            <TextBlock Text="Template" FontSize="12" />
                                        </StackPanel>
                                        <Button.ContextMenu>
                                            <ContextMenu x:Name="TemplateMenu" />
                                        </Button.ContextMenu>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource CmuxButton}"
                                            HorizontalAlignment="Stretch" Margin="2,0,0,0"
                                            ToolTip="New Workspace (Choose Folder)"
                                            Click="NewWorkspaceWithFolder_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       Margin="0,0,6,0" Opacity="0.6" />
                                            <TextBlock Text="Folder" FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Button Command="{Binding ToggleNotificationPanelCommand}"
                                        Style="{StaticResource CmuxButton}"
                                        HorizontalAlignment="Stretch" Margin="0,1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       Margin="0,0,8,0" Opacity="0.6" />
                                            <TextBlock Text="Notifications" FontSize="12" />
                                        </StackPanel>
                                        <Border CornerRadius="10"
                                                Padding="6,2" HorizontalAlignment="Right"
                                                Visibility="{Binding TotalUnreadCount, Converter={StaticResource IntToVisibility}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF6366F1" Offset="0" />
                                                    <GradientStop Color="#FFA78BFA" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding TotalUnreadCount}" FontSize="10"
                                                       Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Vertical divider -->
                <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="10" Background="Transparent"
                              HorizontalAlignment="Stretch" Cursor="SizeWE">
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="GridSplitter">
                            <Grid Background="Transparent">
                                <Border Width="1" Background="{StaticResource BorderBrush}" HorizontalAlignment="Center" />
                            </Grid>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

                <!-- Content area -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Surface tabs -->
                        <RowDefinition Height="Auto" /> <!-- Toolbar -->
                        <RowDefinition Height="*" />    <!-- Terminal content -->
                        <RowDefinition Height="Auto" /> <!-- Status bar -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Surface tabs -->
                    <controls:SurfaceTabBar x:Name="SurfaceTabBarControl" Grid.Row="0" Grid.Column="0"
                        DataContext="{Binding SelectedWorkspace}" />

                    <!-- Toolbar -->
                    <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="6,2">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButton}" ToolTip="Split Right (Ctrl+D)"
                                    Click="ToolbarSplitRight_Click">
                                <TextBlock Text="&#xE26B;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="Split Down (Ctrl+Shift+D)"
                                    Click="ToolbarSplitDown_Click">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button Style="{StaticResource IconButton}" ToolTip="Layout: 2 Columns"
                                    Click="ToolbarLayout2Col_Click">
                                <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="Layout: Grid 2x2"
                                    Click="ToolbarLayoutGrid_Click">
                                <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="Layout: Main + Stack"
                                    Click="ToolbarLayoutMainStack_Click">
                                <TextBlock Text="&#xE89F;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button Style="{StaticResource IconButton}" ToolTip="Equalize Panes"
                                    Click="ToolbarEqualize_Click">
                                <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button x:Name="ToolbarZoomButton" Style="{StaticResource IconButton}" ToolTip="Zoom Pane (Ctrl+Shift+Z)"
                                    Click="ToolbarZoom_Click">
                                <TextBlock x:Name="ToolbarZoomIcon" Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button Style="{StaticResource IconButton}" ToolTip="SSH to macOS VM"
                                    Click="ToolbarSshMac_Click">
                                <Viewbox Width="12" Height="14">
                                    <Path Fill="{StaticResource ForegroundDimBrush}"
                                          Data="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z" />
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="New PowerShell Pane"
                                    Click="ToolbarPowerShell_Click">
                                <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button Style="{StaticResource IconButton}" ToolTip="New Claude Code Tab"
                                    Click="ToolbarClaudeTab_Click">
                                <Viewbox Width="12" Height="12">
                                    <Path Fill="{StaticResource ForegroundDimBrush}"
