                            <Button Style="{StaticResource IconButton}" ToolTip="Expo Start (--clear)"
                                    Click="ToolbarExpoStart_Click">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="EAS Build iOS Dev"
                                    Click="ToolbarEasBuildDev_Click">
                                <TextBlock Text="&#xEC7A;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="EAS Build iOS Preview"
                                    Click="ToolbarEasBuildPreview_Click">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="EAS Update iOS Preview"
                                    Click="ToolbarEasUpdate_Click">
                                <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Terminal content -->
                    <ContentControl Grid.Row="2" Grid.Column="0" x:Name="ContentArea">
                        <controls:SplitPaneContainer x:Name="SplitPaneContainerControl"
                            DataContext="{Binding SelectedWorkspace.SelectedSurface}" />
                    </ContentControl>

                    <!-- Notification panel overlay -->
                    <controls:NotificationPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        HorizontalAlignment="Right"
                        Visibility="{Binding NotificationPanelVisible, Converter={StaticResource BoolToVisibility}}"
                        DataContext="{Binding}" />

                    <!-- Command palette overlay -->
                    <controls:CommandPalette Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        x:Name="CommandPaletteControl"
                        Visibility="Collapsed" />

                    <!-- Snippet picker overlay -->
                    <controls:SnippetPicker Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        x:Name="SnippetPickerControl"
                        Visibility="Collapsed" />

                    <!-- Status bar -->
                    <Border Grid.Row="3" Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Padding="10,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <!-- Git branch -->
                                <TextBlock Text="&#xE8AD;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock Text="{Binding SelectedWorkspace.GitBranch, FallbackValue=''}" FontSize="11"
                                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                           Margin="0,0,16,0" />
                                <!-- Working directory -->
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock Text="{Binding SelectedWorkspace.WorkingDirectory, FallbackValue=''}" FontSize="11"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="300" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <!-- Pane count -->
                                <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock x:Name="PaneCountText" Text="1 pane" FontSize="11"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <!-- Daemon status -->
                                <Border x:Name="DaemonStatusBorder" CornerRadius="3" Padding="5,1" Margin="0,0,12,0"
                                        VerticalAlignment="Center" Background="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="DaemonStatusDot" Width="6" Height="6"
                                                 Fill="#FF6B7280" Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock x:Name="DaemonStatusText" Text="Daemon" FontSize="10"
                                                   Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <!-- Shortcuts hint -->
                                <TextBlock Text="Ctrl+Shift+P: Commands" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
